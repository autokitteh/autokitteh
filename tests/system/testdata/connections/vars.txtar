
ak deploy --manifest manifest.yaml
return code == 0

ak var set test_secret shhhh --secret --connection my_project/my_connection
return code == 0

ak session start -d dep_00000000000000000000000005 --watch --no-timestamps --entrypoint main.star
return code == 0
output contains 'something=test_something'
output contains 'secret=shhhh'

-- manifest.yaml --
version: v1

project:
  name: my_project
  connections:
    - name: my_connection
      integration: slack
      vars:
        - name: something
          value: test_something

-- main.star --
load("env", "my_connection__something", "my_connection__test_secret")

print("something={}".format(my_connection__something))
print("secret={}".format(my_connection__test_secret))
