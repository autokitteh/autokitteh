user zumi

# create a project for zumi
ak project create --name pz
return code == 0

# make sure zumi is its owner
ak project get pz -f
return code == 0
output equals_jq .project.owner_id $ZUMI_UID

user gizmo

# create a project for gizmo
ak project create --name pg
return code == 0

# make sure gizmo is its owner
ak project get pg -f
return code == 0
output equals_jq .project.owner_id $GIZMO_UID

# gizmo and zumi should be able to see each other's projects.
user zumi
ak project get pg -f
return code == 0

user gizmo
ak project get pz -f
return code == 0

# gizmo cannot create a project owned by zumi and vise versa
user gizmo
ak project create --owner $ZUMI_UID
return code == $RC_UNAUTHZ

user zumi
ak project create --owner $GIZMO_UID
return code == $RC_UNAUTHZ

# zumi sees all projects by default
user zumi
ak project list
return code == 0
output equals_jq .[].name pz,pg

# zumi can see gizmo's projects
user zumi
ak project list --owner $GIZMO_UID
return code == 0
output equals_jq .[].name pg

# zumi can build, download and export and download their own project
user zumi
ak project build pz --file main.star
return code == 0

ak project download pz -f
return code == 0

ak project download pz -f
return code == 0

# zumi can build, download and export gizmo's project
ak project build pg --file main.star
return code == 0

ak project download pg -f
return code == 0

ak project export pg
return code == 0

# zumi can delete both her and gizmo's projects
user zumi
ak project delete pg
return code == 0

ak project delete pz
return code == 0

# anonymous users can do nothing
user zumi
ak project create test

user anon

ak project create
return code == $RC_UNAUTHN

ak project get test
return code == $RC_UNAUTHN

ak project delete test
return code == $RC_UNAUTHN

ak project list
return code == $RC_UNAUTHN

ak project download test -f
return code == $RC_UNAUTHN

ak project export test
return code == $RC_UNAUTHN

-- test-config.yaml --
server: 
    opapolicy.config_path: "!single_tenant"
ak:
    extra_args: ["-j", "--array_json_list"]

-- main.star --
def foo(): pass
