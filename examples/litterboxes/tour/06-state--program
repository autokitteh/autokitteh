# Enjoying the good life, when food is always there, our cats are now
# overeating. We need to limit how much they eat. Let's see how we
# can do that.
-- auto.kitteh --
load("ak", "sources", "state") # note that "state" is loaded here too.
load("./cats.cue", "cats")


def _dispense(kind, name):
  # AutoKitteh can maintain state between different invocations of the
  # same project. State consists of named "variables". Here we are
  # querying the variable with the name `name` for its value.
  # TODO: point to list of functions available for state management.
  count = state.get(name, 0)

  limit = cats[name]['limit']

  if count >= limit:
    print('%s already ate %d portions, which is too much' % (name, count))
  else:
    # `inc` assumes that if a variable was not previously set, its
    # value is 0. It also returns the value post-increment. This operation
    # is atomic.
    count = state.inc(name)

    print('dispensing %s food to %s' % (kind, name))
    print('%s so far consumed %d portions' % (name, count))


def _on_sound(ak_ctx, ak_name, sound):
  kind = ak_ctx

  print('%s food dispenser heard a %s' % (kind, sound))

  for name, cfg in cats.items():
    if cfg['sound'] == sound and kind in cfg['kinds']:
      _dispense(kind, name)


sources.bind('wet_dispenser.sound', _on_sound, context='wet')
sources.bind('dry_dispenser.sound', _on_sound, context='dry')

# EVENT gizmo: { "src": "dry_dispenser", "type": "sound", "data": { "sound": { "string": { "v": "meow" } } } }
# EVENT midnight: { "src": "dry_dispenser", "type": "sound", "data": { "sound": { "string": { "v": "grrrr" } } } }
# EVENT pepurr: { "src": "wet_dispenser", "type": "sound", "data": { "sound": { "string": { "v": "purrrr" } } } }
# EVENT zumi: { "src": "wet_dispenser", "type": "sound", "data": { "sound": { "string": { "v": "hiss" } } } }

-- cats.cue --
cats: {
  gizmo: {
    sound: "meow"
    kinds: ["dry"]
    limit: 2
  }
  midnight: {
    sound: "grrrr"
    kinds: ["dry"]
    limit: 5
  }
  pepurr: {
    sound: "purrrr"
    kinds: ["wet", "dry"]
    limit: 3
  }
  zumi: {
    sound: "hiss"
    kinds: ["wet"]
    limit: 7
  }
}

