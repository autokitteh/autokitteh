# Oh no! Sometimes our cats get confused and go to the wrong dispenser.
# When that happens, they don't get the food and NEED TO WALK AAALLL THE WAY TO
# THE OTHER DISPENSER! We cannot let this stand.
#
# We bought a fancy camera that is hooked to both dispensers at the same time.
# When the camera detects a cat, it captures the image and sends us a slug
# to the stored image. In the image, it also superimposes the cat name (it's
# very expensive camera). Let's see how we can use that.
#
# Feel free to mess with the "snap" event. Try out different slugs.
# HINT: 1, 2, 3 and 4 are available.
-- auto.kitteh --
load("ak", "sources")

# To fetch the image, we're using HTTP.
# See https://github.com/qri-io/starlib/tree/master/http.
# For more modules, see https://github.com/qri-io/starlib.
load("http", "http")

# To spice things up, let's use cuelang for our config.
load("./cats.cue", "sounds")

def _on_sound(ak_ctx, ak_name, sound):
  kind = ak_ctx

  print('%s food dispenser heard a %s' % (kind, sound))

  if sound in sounds[kind]:
    print('dispensing %s food to %s' % (kind, sounds[kind][sound]))
  else:
    print('wrong dispenser')


# Handler that get invoked when the camera takes a picture.
def _on_camera_snap(image_slug):
  resp = http.get('http://127.0.0.1:20000/cats/%d' % image_slug)
  if resp.status_code == 200:
    img = resp.body()
    print("received image:\n%s" % img)

    name = img.split('\n')[0]
    print("identified cat: %s" % name)

    for kind in sounds:
      for _, curr in sounds[kind].items():
        if curr == name:
          print("dispensing %s food" % kind)
          return

    print('no match found')
  elif resp.status_code == 404:
    print('could not identify cat')
  else:
    print('oh noes! something went wrong')


sources.bind('wet_dispenser.sound', _on_sound, context='wet')
sources.bind('dry_dispenser.sound', _on_sound, context='dry')
sources.bind('camera.snap', _on_camera_snap)

