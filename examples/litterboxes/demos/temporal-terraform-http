package temporal

import "encoding/json"

plugins: {
  "autokitteh.aws": {}
}

#project_id: string @tag(project_id)

src_bindings: {
  "http": {
    src_id:     "internal.http"
    assoc:      "\( #project_id ).http"
    src_config: json.Marshal({
      name: string @tag(project_name)
      routes: [
        {
          name: "catchall"
          path: "*"
        },
      ]
    })
  }
}
