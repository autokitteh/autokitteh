-- auto.kitteh --
load("ak", "ak")
load("github.com/autokitteh/examples/modules/temporal-terraform/auto.kitteh", "create_network", "destroy_network")


def _create(body_value):
  assert(body_value, "request body expected")
  create_network(**body_value)


def _destroy(body_value):
  assert(body_value, "request body expected")
  destroy_network(**body_value)


ak.sources.bind("http.POST", _create)
ak.sources.bind("http.DELETE", _destroy)

