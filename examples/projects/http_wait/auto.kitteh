load("ak", "sources")
load("encoding/json", "json")


def _on_http_get(query_values):
  ids = query_values.get('id')

  print('waiting for "%s"' % ','.join(ids))

  while True:
    ev = sources.wait(['http.POST'])

    data = json.decode(ev.data['body'])

    for k, v in data.items():
      if k in ids:
        print('got answer for "%s": "%s"' % (k, v))

        ids.remove(k)

        if not ids:
          return


sources.bind('http.GET', _on_http_get)
